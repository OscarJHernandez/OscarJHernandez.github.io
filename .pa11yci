{
  "defaults": {
    "timeout": 30000,
    "standard": "WCAG2AA",
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox"
      ]
    }
  },
  "urls": [
    "http://localhost:4000/",
    "http://localhost:4000/blog/",
    "http://localhost:4000/resume/"
  ]
}
